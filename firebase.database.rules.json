{
  "rules": {
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "devices": {
      "$deviceId": {
        "telemetry": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('deviceOwners').child($deviceId).child('uid').val() === auth.uid"
        },
        "status": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('deviceOwners').child($deviceId).child('uid').val() === auth.uid"
        },
        "commands": {
          ".read": "auth != null",
          "manual": {
            ".write": "auth != null"
          },
          "ack": {
            ".write": "auth != null && root.child('deviceOwners').child($deviceId).child('uid').val() === auth.uid"
          }
        }
      }
    },
    "deviceOwners": {
      "$deviceId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
